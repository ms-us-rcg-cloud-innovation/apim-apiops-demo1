{
  "properties": {
    "loggerId": "/loggers/azuremonitor",
    "backend": {
      "request": {
        "dataMasking": {
          "queryParams": [
            {
              "mode": "Hide",
              "value": "*"
            }
          ]
        }
      }
    },
    "frontend": {
      "request": {
        "dataMasking": {
          "queryParams": [
            {
              "mode": "Hide",
              "value": "*"
            }
          ]
        }
      }
    },
    "logClientIp": true,
    "sampling": {
      "percentage": 100,
      "samplingType": "fixed"
    }
  }
}