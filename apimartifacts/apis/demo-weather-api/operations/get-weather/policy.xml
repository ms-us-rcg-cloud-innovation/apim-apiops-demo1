<policies>
	<inbound>
		<base />
		<set-variable name="city" value="@(((string)context.Request.MatchedParameters[&quot;city&quot;]).ToLower())" />
		<choose>
			<when condition="@((string)context.Variables[&quot;city&quot;] == &quot;seattle&quot;)">
				<return-response>
					<set-status code="200" reason="OK" />
					<set-header name="X-Scope-Global" exists-action="override">
						<value>@((string)context.Variables.GetValueOrDefault(&quot;scope-global&quot;,&quot;not-run&quot;))</value>
					</set-header>
					<set-header name="X-Scope-Product" exists-action="override">
						<value>@((string)context.Variables.GetValueOrDefault(&quot;scope-product&quot;,&quot;not-run&quot;))</value>
					</set-header>
					<set-header name="X-Scope-Api" exists-action="override">
						<value>@((string)context.Variables.GetValueOrDefault(&quot;scope-api&quot;,&quot;not-run&quot;))</value>
					</set-header>
					<set-header name="X-Correlation-Id" exists-action="override">
						<value>@((string)context.Variables.GetValueOrDefault(&quot;correlationId&quot;,&quot;none&quot;))</value>
					</set-header>
					<set-header name="X-Environment" exists-action="override">
						<value>{{demo-environment}}</value>
					</set-header>
					<set-header name="X-Powered-By" exists-action="override">
						<value>APIM-Demo</value>
					</set-header>
					<set-header name="Content-Type" exists-action="override">
						<value>application/json</value>
					</set-header>
					<set-header name="X-Scope-Operation" exists-action="override">
						<value>get-weather</value>
					</set-header>
					<set-body>{"city":"Seattle","tempC":12,"conditions":"Rain"}</set-body>
				</return-response>
			</when>
			<when condition="@((string)context.Variables[&quot;city&quot;] == &quot;miami&quot;)">
				<return-response>
					<set-status code="200" reason="OK" />
					<set-header name="X-Scope-Global" exists-action="override">
						<value>@((string)context.Variables.GetValueOrDefault(&quot;scope-global&quot;,&quot;not-run&quot;))</value>
					</set-header>
					<set-header name="X-Scope-Product" exists-action="override">
						<value>@((string)context.Variables.GetValueOrDefault(&quot;scope-product&quot;,&quot;not-run&quot;))</value>
					</set-header>
					<set-header name="X-Scope-Api" exists-action="override">
						<value>@((string)context.Variables.GetValueOrDefault(&quot;scope-api&quot;,&quot;not-run&quot;))</value>
					</set-header>
					<set-header name="X-Correlation-Id" exists-action="override">
						<value>@((string)context.Variables.GetValueOrDefault(&quot;correlationId&quot;,&quot;none&quot;))</value>
					</set-header>
					<set-header name="X-Environment" exists-action="override">
						<value>{{demo-environment}}</value>
					</set-header>
					<set-header name="X-Powered-By" exists-action="override">
						<value>APIM-Demo</value>
					</set-header>
					<set-header name="Content-Type" exists-action="override">
						<value>application/json</value>
					</set-header>
					<set-header name="X-Scope-Operation" exists-action="override">
						<value>get-weather</value>
					</set-header>
					<set-body>{"city":"Miami","tempC":29,"conditions":"Sunny"}</set-body>
				</return-response>
			</when>
			<otherwise>
				<return-response>
					<set-status code="200" reason="OK" />
					<set-header name="X-Scope-Global" exists-action="override">
						<value>@((string)context.Variables.GetValueOrDefault(&quot;scope-global&quot;,&quot;not-run&quot;))</value>
					</set-header>
					<set-header name="X-Scope-Product" exists-action="override">
						<value>@((string)context.Variables.GetValueOrDefault(&quot;scope-product&quot;,&quot;not-run&quot;))</value>
					</set-header>
					<set-header name="X-Scope-Api" exists-action="override">
						<value>@((string)context.Variables.GetValueOrDefault(&quot;scope-api&quot;,&quot;not-run&quot;))</value>
					</set-header>
					<set-header name="X-Correlation-Id" exists-action="override">
						<value>@((string)context.Variables.GetValueOrDefault(&quot;correlationId&quot;,&quot;none&quot;))</value>
					</set-header>
					<set-header name="X-Environment" exists-action="override">
						<value>{{demo-environment}}</value>
					</set-header>
					<set-header name="X-Powered-By" exists-action="override">
						<value>APIM-Demo</value>
					</set-header>
					<set-header name="Content-Type" exists-action="override">
						<value>application/json</value>
					</set-header>
					<set-header name="X-Scope-Operation" exists-action="override">
						<value>get-weather</value>
					</set-header>
					<set-body>@{ return &quot;{\&quot;city\&quot;:\&quot;&quot; + (string)context.Variables[&quot;city&quot;] + &quot;\&quot;,\&quot;tempC\&quot;:20,\&quot;conditions\&quot;:\&quot;Cloudy\&quot;}&quot;; }</set-body>
				</return-response>
			</otherwise>
		</choose>
	</inbound>
	<backend>
		<base />
	</backend>
	<outbound>
		<base />
	</outbound>
	<on-error>
		<base />
	</on-error>
</policies>