<policies>
	<inbound>
		<base />
		<include-fragment fragment-id="correlation-id" />
		<set-variable name="scope-api" value="demo-weather-api" />
	</inbound>
	<backend>
		<base />
	</backend>
	<outbound>
		<base />
		<set-header name="X-Scope-Api" exists-action="override">
			<value>demo-weather-api</value>
		</set-header>
		<set-header name="X-Correlation-Id" exists-action="override">
			<value>@((string)context.Variables[&quot;correlationId&quot;])</value>
		</set-header>
	</outbound>
	<on-error>
		<base />
	</on-error>
</policies>