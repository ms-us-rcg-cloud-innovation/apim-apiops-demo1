<policies>
	<inbound>
		<base />
		<rate-limit-by-key calls="2" renewal-period="30" counter-key="@(context.Subscription.Id + &quot;:create-order&quot;)" remaining-calls-header-name="X-Op-RateLimit-Remaining" total-calls-header-name="X-Op-RateLimit-Limit" />
		<return-response>
			<set-status code="201" reason="Created" />
			<set-header name="X-Scope-Global" exists-action="override">
				<value>@((string)context.Variables.GetValueOrDefault(&quot;scope-global&quot;,&quot;not-run&quot;))</value>
			</set-header>
			<set-header name="X-Scope-Product" exists-action="override">
				<value>@((string)context.Variables.GetValueOrDefault(&quot;scope-product&quot;,&quot;not-run&quot;))</value>
			</set-header>
			<set-header name="X-Scope-Api" exists-action="override">
				<value>@((string)context.Variables.GetValueOrDefault(&quot;scope-api&quot;,&quot;not-run&quot;))</value>
			</set-header>
			<set-header name="X-Correlation-Id" exists-action="override">
				<value>@((string)context.Variables.GetValueOrDefault(&quot;correlationId&quot;,&quot;none&quot;))</value>
			</set-header>
			<set-header name="X-Environment" exists-action="override">
				<value>{{demo-environment}}</value>
			</set-header>
			<set-header name="X-Powered-By" exists-action="override">
				<value>APIM-Demo</value>
			</set-header>
			<set-header name="Content-Type" exists-action="override">
				<value>application/json</value>
			</set-header>
			<set-header name="X-Scope-Operation" exists-action="override">
				<value>create-order</value>
			</set-header>
			<set-body>{"orderId":"o-9999","status":"created","message":"Order created (mocked)"}</set-body>
		</return-response>
	</inbound>
	<backend>
		<base />
	</backend>
	<outbound>
		<base />
	</outbound>
	<on-error>
		<base />
	</on-error>
</policies>