<policies>
	<inbound>
		<set-variable name="scope-global" value="ran" />
		<set-variable name="env" value="{{demo-environment}}" />
		<cors allow-credentials="true" terminate-unmatched-request="false">
			<allowed-origins>
				<origin>https://apim-networked-a.developer.azure-api.net</origin>
			</allowed-origins>
			<allowed-methods preflight-result-max-age="300">
				<method>*</method>
			</allowed-methods>
			<allowed-headers>
				<header>*</header>
			</allowed-headers>
			<expose-headers>
				<header>*</header>
			</expose-headers>
		</cors>
	</inbound>
	<backend>
		<forward-request />
	</backend>
	<outbound>
		<set-header name="X-Powered-By" exists-action="override">
			<value>APIM-Demo</value>
		</set-header>
		<set-header name="X-Environment" exists-action="override">
			<value>{{demo-environment}}</value>
		</set-header>
		<set-header name="X-Scope-Global" exists-action="override">
			<value>ran</value>
		</set-header>
	</outbound>
	<on-error />
</policies>